DJANGO_SECRET_KEY=replace-with-secure-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Use mysql to work with phpMyAdmin. Switch to sqlite if needed.
DB_BACKEND=mysql

# MySQL connection (XAMPP/WAMP defaults often: user=root, password empty)
MYSQL_DATABASE=school_db
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

